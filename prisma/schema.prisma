generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum RoleType {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UomType {
  NUMERIC
  PERCENTAGE
  TIMELINE
  ZERO_BASED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  RETURNED_FOR_REWORK
  APPROVED
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          RoleType  @default(EMPLOYEE)
  managerId     String?
  manager       User?     @relation("ManagerToEmployee", fields: [managerId], references: [id])
  employees     User[]    @relation("ManagerToEmployee")
  
  goals         Goal[]    @relation("UserGoals")
  sharedGoals   Goal[]    @relation("SharedGoals")
  checkIns      CheckIn[]
  comments      Comment[]
  notifications Notification[]
  auditLogs     AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Goal {
  id          String       @id @default(cuid())
  title       String
  description String?
  weightage   Int          @default(10)
  status      GoalStatus   @default(DRAFT)
  priority    GoalPriority @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  progress    Int          @default(0)
  uomType UomType @default(NUMERIC)
  target  String?

  isShared        Boolean @default(false)
isPrimaryOwner  Boolean @default(false)

parentGoalId    String?
parentGoal      Goal?   @relation("SharedGoalLink", fields: [parentGoalId], references: [id])

linkedGoals     Goal[]  @relation("SharedGoalLink")
  userId      String
  user        User         @relation("UserGoals", fields: [userId], references: [id], onDelete: Cascade)
  
  sharedWith  User[]       @relation("SharedGoals")
  
  checkIns    CheckIn[]
  comments    Comment[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CheckIn {
  id           String   @id @default(cuid())
  progress     Int      @default(0)
  notes        String?
  achievements String?
  blockers     String?
  nextSteps    String?
  
  goalId       String
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  message     String
  isRead      Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  details     String?
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}
